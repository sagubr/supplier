{
	"compilerOptions": {
		"target": "ES2024",
		"module": "CommonJS",
		"moduleResolution": "node",
		"rootDir": ".",
		"baseUrl": "src",
		"paths": {
			"@/*": ["*"]
		},
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true
	},
	"include": ["src", "vitest.config.ts"]
}
