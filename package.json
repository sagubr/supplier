{
	"name": "api",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"dev": "NODE_ENV=development ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/apps/api/server.ts | pino-pretty",
		"dev:worker": "SERVICE_NAME=quality-worker NODE_ENV=development ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/apps/worker/worker.bootstrap.ts",
		"dev:watchdog": "SERVICE_NAME=quality-watchdog NODE_ENV=development ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/apps/watchdog/watchdog.bootstrap.ts",
		"build": "tsc && tsc-alias",
		"start": "node dist/apps/api/server.js",
		"start:worker": "node dist/apps/worker/worker.bootstrap.js",
		"start:watchdog": "node dist/apps/watchdog/watchdog.bootstrap.js"
	},
	"dependencies": {
		"@sendgrid/mail": "^8.1.6",
		"@sentry/node": "^10.38.0",
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"express": "^5.2.1",
		"helmet": "^8.1.0",
		"mysql2": "^3.17.2",
		"node-cache": "^5.1.2",
		"nodemailer": "^8.0.1",
		"pino": "^10.3.1",
		"pino-http": "^11.0.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.2.3",
		"@types/node-cache": "^4.1.3",
		"@types/nodemailer": "^7.0.10",
		"pino-pretty": "^13.1.3",
		"ts-node-dev": "^2.0.0",
		"tsc-alias": "^1.8.16",
		"typescript": "^5.9.3",
		"tsconfig-paths": "^4.2.0"
	}
}
